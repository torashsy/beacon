# Supabase プロジェクトの Settings → API からコピー
# 実際の値は .env.local に入れる（.env.local は git 管理外）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase Edge Function create-avatar-upload 側のSecretとして設定する（ブラウザ用ではない）
# BEACON_ALLOWED_ORIGINS=https://your-domain.example

# ↑ publishable キーだけで完結する設計。
#   認証・書き込みはすべて schema.sql の RPC がサーバー側で検証するため、
#   service_role キーはブラウザ/Vercelでは使わない（Edge Function組み込み環境のみ）。
